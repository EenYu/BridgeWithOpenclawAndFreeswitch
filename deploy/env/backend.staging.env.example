# Bridge runtime identity
BRIDGE_VERSION=0.1.0-staging
BRIDGE_NODE_NAME=bridge-staging-1
BRIDGE_HTTP_ADDR=:8080

# Public ingress details used by reverse proxy and FreeSWITCH integration docs
BRIDGE_PUBLIC_BASE_URL=https://bridge.example.com
BRIDGE_PUBLIC_WS_URL=wss://bridge.example.com/ws/freeswitch/stream
BRIDGE_DASHBOARD_WS_URL=wss://bridge.example.com/ws

# WebSocket hardening
BRIDGE_WS_DASHBOARD_AUTH_TOKEN=
BRIDGE_WS_DASHBOARD_ALLOWED_ORIGINS=https://console.example.com,http://127.0.0.1:5173
BRIDGE_WS_DASHBOARD_ALLOW_EMPTY_ORIGIN=false
BRIDGE_WS_FREESWITCH_AUTH_TOKEN=
BRIDGE_WS_FREESWITCH_ALLOWED_ORIGINS=
BRIDGE_WS_FREESWITCH_ALLOW_EMPTY_ORIGIN=true
BRIDGE_WS_BROADCAST_QUEUE_SIZE=32
BRIDGE_WS_WRITE_TIMEOUT_MS=2000

# Media contract frozen for v1
BRIDGE_PCM_ENCODING=pcm_s16le
BRIDGE_PCM_SAMPLE_RATE_HZ=16000
BRIDGE_PCM_CHANNELS=1
BRIDGE_PCM_FRAME_MS=20

# Reverse proxy / network edge
BRIDGE_TLS_TERMINATES_AT=edge-proxy
BRIDGE_EXPECT_X_FORWARDED_PROTO=true

# STT: Volcengine big-model streaming ASR over WebSocket binary protocol
BRIDGE_STT_VENDOR=volcengine-stt-ws
BRIDGE_STT_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
BRIDGE_STT_MODEL=bigmodel
BRIDGE_STT_TRANSPORT=volcengine-binary-ws
# Recommended names aligned with workflow.md; code also accepts legacy BRIDGE_STT_APP_KEY / BRIDGE_STT_API_KEY
BRIDGE_STT_APP_ID=
BRIDGE_STT_ACCESS_TOKEN=
BRIDGE_STT_RESOURCE_ID=volc.seedasr.sauc.duration
BRIDGE_STT_UID=bridge-fs1
BRIDGE_STT_LANGUAGE=
BRIDGE_STT_AUDIO_FORMAT=pcm
BRIDGE_STT_AUDIO_CODEC=raw
BRIDGE_STT_SAMPLE_RATE_HZ=16000
BRIDGE_STT_BITS_PER_SAMPLE=16
BRIDGE_STT_ENABLE_ITN=true
BRIDGE_STT_ENABLE_PUNCTUATION=true
BRIDGE_STT_SHOW_UTTERANCES=true
BRIDGE_STT_TIMEOUT_MS=10000

# OpenClaw: real deployment is currently the FS1 local loopback gateway; backend should run on the same host
BRIDGE_OPENCLAW_VENDOR=openclaw-gateway-ws
BRIDGE_OPENCLAW_ENDPOINT=ws://127.0.0.1:18789
BRIDGE_OPENCLAW_ORIGIN=http://127.0.0.1
BRIDGE_OPENCLAW_MODEL=default
BRIDGE_OPENCLAW_API_KEY=
BRIDGE_OPENCLAW_API_KEY_HINT=oc_***
BRIDGE_OPENCLAW_TIMEOUT_MS=10000

# TTS: Volcengine bidirectional WebSocket V3; prefer wav/8000 for mod_audio_stream playback compatibility
BRIDGE_TTS_VENDOR=volcengine-tts-ws-v3
BRIDGE_TTS_ENDPOINT=wss://openspeech.bytedance.com/api/v3/tts/bidirection
BRIDGE_TTS_STS_ENDPOINT=https://openspeech.bytedance.com/api/v1/sts/token
BRIDGE_TTS_NAMESPACE=BidirectionalTTS
BRIDGE_TTS_APP_KEY=
BRIDGE_TTS_API_KEY=
BRIDGE_TTS_RESOURCE_ID=volc.service_type.10029
BRIDGE_TTS_VOICE_TYPE=
BRIDGE_TTS_UID=bridge-fs1
BRIDGE_TTS_AUDIO_FORMAT=wav
BRIDGE_TTS_SAMPLE_RATE_HZ=8000
BRIDGE_TTS_TIMEOUT_MS=30000
